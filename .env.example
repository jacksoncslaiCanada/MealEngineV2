# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mealengine

# Reddit — no credentials needed (uses public JSON API)
# REDDIT_USER_AGENT is optional; defaults to MealEngineV2/1.0
# REDDIT_USER_AGENT=MealEngineV2/1.0

# YouTube Data API v3 (https://console.cloud.google.com/)
YOUTUBE_API_KEY=your_youtube_api_key
